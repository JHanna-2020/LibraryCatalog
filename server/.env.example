# Copy this file to ".env" and fill in your own values.
# The server reads these when it starts.

# Password required to add/edit/delete books and to check books in/out.
# Anyone WITHOUT this password can still VIEW the catalog (read-only).
# Pick something only you know.
ADMIN_PASSWORD=change-me-please

# Port the server listens on locally. 4000 is fine; change only if it clashes.
PORT=4000

# OPTIONAL: free Google Gemini API key for AI-assisted ISBN lookup.
# Used ONLY as a fallback when a scanned ISBN isn't in Open Library or Google
# Books (e.g. small-press Coptic titles). Get a free key at
# https://aistudio.google.com/apikey and DO NOT enable billing — then it can
# never cost anything. Leave blank to disable the AI fallback entirely.
GEMINI_API_KEY=
# Optional: override the model (default gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of website origins allowed to call this API.
# Include your GitHub Pages URL once you know it, e.g.
#   https://yourname.github.io
# Leave the "*" during first setup if you want to allow any origin, then lock it down.
ALLOWED_ORIGINS=*
